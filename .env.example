# =============================================================================
# Multi-Modal Agentic RAG - Environment Template
# =============================================================================
# Copy this file to .env and add your personal API keys:
#     cp .env.example .env
#     nano .env  # Add your DEEPSEEK_API_KEY
#
# This file is identical to .env.defaults (safe to share)
# Your .env file will contain sensitive data (DO NOT share)
# =============================================================================
# =============================================================================
# Multi-Modal Agentic RAG - Default Configuration
# =============================================================================
# This file contains SHAREABLE default settings.
# These are safe to commit to git and share with your team.
#
# For your personal/sensitive settings, copy this to .env and add:
# - DEEPSEEK_API_KEY (your personal API key)
# - Any other secrets or personal overrides
#
# Priority: .env (personal) > .env.defaults (team defaults) > code defaults
# =============================================================================

# -----------------------------------------------------------------------------
# Phoenix Observability
# -----------------------------------------------------------------------------
# Enable Phoenix tracing for multi-agent workflow
# Options: true, false
PHOENIX_ENABLED=true

# Phoenix collector endpoint (for remote Phoenix instances)
# Default: http://localhost:6006/v1/traces
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# -----------------------------------------------------------------------------
# Ollama (Local Models) - DEPRECATED: Using HuggingFace instead
# -----------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_QUERY_MODEL=qwen3:8b
# OLLAMA_VISION_MODEL=qwen3-vl:8b

# -----------------------------------------------------------------------------
# DeepSeek: Hybrid Configuration (API default, local fallback)
# -----------------------------------------------------------------------------
# Mode: "api" (default) or "local"
DEEPSEEK_MODE=api

# API Configuration (used when DEEPSEEK_MODE=api)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here  # Add this to your personal .env
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Local Fallback Configuration (used when DEEPSEEK_MODE=local or API fails)
DEEPSEEK_FALLBACK_TO_LOCAL=true
DEEPSEEK_FALLBACK_MODEL=deepseek-r1:8b

# -----------------------------------------------------------------------------
# HuggingFace Models (Embeddings + Reranker)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B
RERANKER_MODEL=Qwen/Qwen3-VL-Reranker-2B

# Model cache directory
HF_HOME=/root/.cache/huggingface

# -----------------------------------------------------------------------------
# RAG-Anything Configuration
# -----------------------------------------------------------------------------
RAG_WORKING_DIR=./rag_storage
RAG_ENABLE_IMAGE_PROCESSING=true
RAG_ENABLE_TABLE_PROCESSING=true
RAG_ENABLE_EQUATION_PROCESSING=true

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json  # "json" or "text"
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# Data Ingestion Configuration
# -----------------------------------------------------------------------------
DATA_DIR=./data
IMAGE_DIR=./data/images
CSV_PATH=./data/claim_matching_dataset.csv

# Image download settings
IMAGE_DOWNLOAD_TIMEOUT=10  # seconds
IMAGE_DOWNLOAD_WORKERS=5   # concurrent downloads (reduced from 10 for 12GB GPU)
IMAGE_DOWNLOAD_RETRY=3     # retry attempts

# -----------------------------------------------------------------------------
# GPU Configuration (Full GPU Migration - HuggingFace Qwen3)
# -----------------------------------------------------------------------------
USE_GPU=true                # Enable GPU acceleration (requires CUDA)
DEVICE=cuda                 # Device for GPU models (cuda/cpu)
TORCH_DTYPE=float16         # Data type for GPU models (float16/float32)

# Qwen3 Models (HuggingFace)
# Using Qwen3-VL-2B-Instruct for both vision and text (smaller, newer model)
VISION_MODEL=Qwen/Qwen3-VL-2B-Instruct  # NEW: Vision model (2B for 12GB GPU - better than Qwen2.5-VL-3B)
TEXT_LLM_MODEL=Qwen/Qwen3-VL-2B-Instruct  # NEW: Text model (same as vision for unified model)

# 8-Bit Quantization (for 12GB VRAM optimization)
USE_8BIT_QUANTIZATION=true  # Enable 8-bit quantization (~50% memory reduction)
QUANTIZATION_TYPE=q4_k_m    # Legacy quantization type (unused with 8-bit)
BATCH_SIZE=1                # Batch size for GPU inference (reduced to 1 for stability)
EMBEDDING_BATCH_SIZE=8      # Batch size for embeddings

# Memory Management (CUDA OOM fixes)
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
ENABLE_MEMORY_MONITORING=true

# -----------------------------------------------------------------------------
# Evaluation Configuration
# -----------------------------------------------------------------------------
TEST_SET_SIZE=20  # number of test queries for evaluation
EVAL_OUTPUT_DIR=./reports

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
# Number of documents to retrieve
RETRIEVAL_TOP_K=50
RERANK_TOP_K=10

# Confidence threshold
CONFIDENCE_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Performance Settings
# -----------------------------------------------------------------------------
# Embedding batch size
EMBEDDING_BATCH_SIZE=32

# Max concurrent requests
MAX_CONCURRENT_REQUESTS=5

# Request timeout (seconds)
REQUEST_TIMEOUT=120

# -----------------------------------------------------------------------------
# Parser Configuration
# -----------------------------------------------------------------------------
PARSER=docling  # Use docling instead of mineru (avoids transformers version conflict)

# =============================================================================
# Usage Instructions
# =============================================================================
#
# 1. First Time Setup:
#    cp .env.defaults .env
#    # Edit .env and add your DEEPSEEK_API_KEY
#
# 2. Team Collaboration:
#    - Commit .env.defaults to git (safe to share)
#    - Add .env to .gitignore (personal, contains secrets)
#    - Each team member has their own .env with their API keys
#
# 3. Override Defaults:
#    # In your personal .env
#    PHOENIX_ENABLED=true  # Override the default
#    LOG_LEVEL=DEBUG       # Override the default
#
# 4. Phoenix Observability:
#    - Set PHOENIX_ENABLED=true to start tracing
#    - Start Phoenix UI: python -m phoenix.server.main serve
#    - View traces at: http://localhost:6006
#
# 5. DeepSeek API:
#    - Get free API key at: https://platform.deepseek.com/
#    - $0.14 per million tokens (very cost-effective)
#    - Falls back to local Qwen3-8B if API fails
#
# =============================================================================
